+
+    fn clamp_bezier_handles(points: [PointF64; 4]) -> [PointF64; 4] {
+        let [a, mut b, mut c, d] = points;
+        let chord = norm(&(d - a));
+        if chord < f64::EPSILON {
+            return [a, b, c, d];
+        }
+        let max_handle = chord * 0.55;
+        b = Self::clamp_handle(a, b, max_handle);
+        c = Self::clamp_handle(d, c, max_handle);
+        [a, b, c, d]
+    }
+
+    fn clamp_handle(anchor: PointF64, handle: PointF64, max_length: f64) -> PointF64 {
+        let delta = handle - anchor;
+        let length = norm(&delta);
+        if length <= max_length || length < f64::EPSILON {
+            return handle;
+        }
+        anchor + delta.get_normalized() * max_length
+    }
